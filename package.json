{
  "name": "yuan-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "一套精致的 Vue 3 UI 组件库",
  "main": "./dist/yuan-ui.umd.js",
  "module": "./dist/yuan-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/yuan-ui.es.js",
      "require": "./dist/yuan-ui.umd.js",
      "default": "./dist/yuan-ui.es.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@vueuse/core": "^10.9.0",
    "markstream-vue": "^1.0.0",
    "nanoid": "^5.0.6",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.4.2",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "ui",
    "reasoning",
    "component",
    "chain-of-thought"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neoyuan/yuan-ui"
  }
}
