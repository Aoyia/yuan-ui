{
  "name": "yuan-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "一套对标大厂品质的 Vue 3 智能体思维链/执行轨迹 UI 组件库",
  "main": "./dist/yuan-ui.umd.js",
  "module": "./dist/yuan-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/yuan-ui.es.js",
      "require": "./dist/yuan-ui.umd.js",
      "default": "./dist/yuan-ui.es.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@vueuse/core": "^10.9.0",
    "markstream-vue": "^1.0.0",
    "nanoid": "^5.0.6",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/language-core": "^3.3.5",
    "typescript": "^6.0.3",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^5.0.3",
    "vitepress": "^1.2.0",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run src",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue",
    "ui",
    "reasoning",
    "component",
    "chain-of-thought",
    "agent",
    "trace"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neoyuan/yuan-ui"
  }
}
